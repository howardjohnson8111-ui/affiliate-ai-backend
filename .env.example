# Google Gemini API
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Secure scheduler endpoint for cron jobs
SCHEDULER_TOKEN=AiPro2026SchedulerToken9f8k3d2s1

# Backup Providers (Person of Interest)
FIREBASE_CONFIG={}
AWS_CONFIG={}
MONGODB_CONFIG={}
POSTGRES_CONFIG={}
REDIS_CONFIG={}
S3_CONFIG={}
GCS_CONFIG={}

# Maximum Security Settings
REQUIRE_VPN=true
REQUIRE_HARDWARE_KEY=true
REQUIRE_BIOMETRIC=true
REQUIRE_FACE_SCAN=true
HARDWARE_KEY_ID=your_yubikey_id_here
HARDWARE_KEY_SIGNATURE=your_yubikey_signature_here
BIOMETRIC_CREDENTIAL_ID=your_webauthn_credential_id_here
BIOMETRIC_CHALLENGE=your_biometric_challenge_here
FACE_SCAN_THRESHOLD=0.95
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Twilio SMS Alerts
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1your_twilio_number

# Node.js Backend
PORT=3001
NODE_ENV=development

# Frontend (React PWA)
REACT_APP_API_URL=http://localhost:3001
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key_here

# Python AI Service
PYTHON_PORT=5000
